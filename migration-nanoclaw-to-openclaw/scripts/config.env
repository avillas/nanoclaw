# ============================================================================
# Configuracao da Migracao NanoClaw -> OpenClaw
# Edite este arquivo ANTES de executar os scripts
# ============================================================================

# --- Paths -------------------------------------------------------------------

# Diretorio do NanoClaw (origem)
# Detectado automaticamente se nao definido
# NANOCLAW_DIR="$HOME/nanoclaw"

# Diretorio de estado do OpenClaw (destino)
# OpenClaw armazena configs, workspace e dados aqui (NAO e um projeto Node)
OPENCLAW_DIR="$HOME/.openclaw"

# --- Instalacao do OpenClaw (Fase 0) ----------------------------------------

# Versao do Node.js a instalar (se nao presente). OpenClaw requer Node 22.14+ ou 24
NODE_MAJOR=22

# --- Conectividade -----------------------------------------------------------

# Host remoto (deixe vazio para migracao local no mesmo servidor)
# Formato: user@hostname ou alias SSH
REMOTE_HOST=""

# --- Dashboard ---------------------------------------------------------------

# Onde instalar o dashboard Mission Control (fora do ~/.openclaw)
DASHBOARD_DIR="$HOME/openclaw-dashboard"

# Porta do Dashboard Mission Control
DASHBOARD_PORT=3000

# --- Limites -----------------------------------------------------------------

# Espaco minimo em disco (GB) para prosseguir
MIN_DISK_GB=5
