# NanoClaw Mission Control

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-min-32-chars-here

# Auth credentials (for CredentialsProvider)
ADMIN_EMAIL=admin@nanoclaw.local
ADMIN_PASSWORD=changeme

# NanoClaw SQLite database path
NANOCLAW_DB_PATH=../store/messages.db

# Container runtime: "docker" | "apple-container" | auto-detect if omitted
# CONTAINER_RUNTIME=docker

# Docker socket (used when runtime is Docker)
DOCKER_SOCKET=/var/run/docker.sock

# Apple Container CLI path (used when runtime is apple-container, defaults to "container")
# APPLE_CONTAINER_CLI=/usr/local/bin/container

# NanoClaw installation path
NANOCLAW_ROOT=..
