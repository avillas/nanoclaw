# Ollama — local model runtime (default: 172.17.0.1:11434 from container POV)
OLLAMA_HOST=http://172.17.0.1:11434
# Pre-filter inbound messages with Ollama before invoking Claude.
# Saves tokens on trivial messages (greetings, acks, simple Q&A).
OLLAMA_PREFILTER_ENABLED=false
OLLAMA_PREFILTER_MODEL=qwen3:8b

# OpenRouter — multi-model access (GPT-4o, Gemini, DeepSeek, Llama, etc.)
# Get your API key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=anthropic/claude-sonnet-4
